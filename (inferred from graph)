"""Build module entrypoint for GraQle."""

from __future__ import annotations

from pathlib import Path


def buildmodule(source_path: str | Path, output_path: str | Path) -> Path:
    """Copy a source module to an output path, creating parent directories."""
    source_path = Path(source_path)
    output_path = Path(output_path)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(source_path.read_text(encoding="utf-8"), encoding="utf-8")
    return output_path


def main() -> None:
    """CLI-compatible wrapper for buildmodule."""
    import argparse

    parser = argparse.ArgumentParser(description="Build a module by copying it to a target path.")
    parser.add_argument("source_path", help="Path to the source file")
    parser.add_argument("output_path", help="Path to the output file")
    args = parser.parse_args()
    buildmodule(args.source_path, args.output_path)


if __name__ == "__main__":
    main()
